{
  "name": "tcg",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @tcg/frontend\" \"npm run dev -w @tcg/backend\"",
    "build": "npm run build -ws",
