PORT=4000
# Comma-separated allowed frontend origins
CORS_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/tcg?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret

# ---- Password reset email ----
# Provider: "brevo" | "resend" | "smtp". Leave blank to auto-detect
# (Brevo if BREVO_API_KEY set, else Resend if RESEND_API_KEY set, else SMTP).
MAIL_PROVIDER=
# Must be a sender that the chosen provider is allowed to send from.
EMAIL_FROM=Chronicles of the Rift <you@example.com>
RESET_PASSWORD_URL=http://localhost:5173

# Brevo (recommended free: 300/day, NO domain needed — just verify a single
# sender at app.brevo.com → Senders. Works on Render via HTTPS).
BREVO_API_KEY=

# Resend (needs a VERIFIED DOMAIN to send to arbitrary recipients)
RESEND_API_KEY=re_xxxxx

# SMTP (e.g. Gmail beta — no custom domain needed)
# Gmail: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com
# SMTP_PASS=<16-char Google App Password>  (NOT your normal password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
