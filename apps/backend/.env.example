PORT=4000
# Comma-separated allowed frontend origins
CORS_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/tcg?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret

# ---- Password reset email ----
# Provider: "resend" or "smtp". Leave blank to auto-detect
# (Resend if RESEND_API_KEY is set, else SMTP if SMTP_HOST is set).
MAIL_PROVIDER=
EMAIL_FROM=TCG Support <onboarding@resend.dev>
RESET_PASSWORD_URL=http://localhost:5173

# Resend (primary, once you have a verified domain)
RESEND_API_KEY=re_xxxxx

# SMTP (e.g. Gmail beta — no custom domain needed)
# Gmail: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com
# SMTP_PASS=<16-char Google App Password>  (NOT your normal password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
